PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/cidadeativa

# PostgreSQL
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/cidadeativa
# (se preferir, pode usar PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE)

# S3 (upload via API /api/upload)
AWS_REGION=us-east-1
AWS_S3_BUCKET=projetos-cn
# Obrigatorias para PutObject no SDK (Learner Lab costuma ter credenciais temporarias)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional: credenciais temporarias (Learner Lab / STS)
# AWS_SESSION_TOKEN=